# Copy to .env locally, or set these in Coolify → Environment Variables

# Long random secret (required). Generate with:
# openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# Existing Ollama host (Cortex / LAN)
OLLAMA_BASE_URL=http://10.0.0.1:11434
OLLAMA_BASE_URLS=http://10.0.0.1:11434

# Force env over DB-persisted Admin → Connections settings
ENABLE_PERSISTENT_CONFIG=False
# One-shot: rewrite DB config from env on container start (set False after first good boot)
RESET_CONFIG_ON_START=True

ENABLE_OPENAI_API=False
OPENAI_API_KEY=
OPENAI_API_BASE_URL=

WEBUI_AUTH=True
ENABLE_SIGNUP=True
